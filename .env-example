# ============================================================
# JOB ASSIST — Environment Configuration
# Duplicate this file as `.env.local` or `.env` and fill in your values.
# NEVER commit your actual configuration with real keys to version control.
# ============================================================

# --- AI PROVIDER KEYS ---
# You only need to fill in the provider(s) you intend to use.

# OpenAI (for GPT-4o models)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key_here"

# Google Gemini (for Gemini 2.5 Flash models)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"


# --- LOCAL LLM CONFIG (OLLAMA) ---
# Used when selecting the "Local Node" provider in the UI.

# When running locally (no Docker): http://localhost:11434/v1
# When running with Docker Compose: http://ollama:11434/v1
LOCAL_LLM_URL="http://localhost:11434/v1"

# The model to use. Must be pulled first via `ollama pull <model>`
# Popular options: llama3, mistral, phi3
LOCAL_LLM_MODEL="llama3"


# --- APP CONFIG ---
NODE_ENV="development"
PORT=3000
